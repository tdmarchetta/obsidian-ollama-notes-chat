{
  "name": "obsidian-ollama-notes-chat",
  "version": "0.7.19",
  "description": "Chat with your notes in a right sidebar using a remote Ollama server.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "ollama",
    "ai",
    "chat"
  ],
  "author": "Taylor Marchetta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tdmarchetta/obsidian-ollama-notes-chat.git"
  },
  "bugs": {
    "url": "https://github.com/tdmarchetta/obsidian-ollama-notes-chat/issues"
  },
  "homepage": "https://github.com/tdmarchetta/obsidian-ollama-notes-chat#readme",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.0.0"
  }
}
